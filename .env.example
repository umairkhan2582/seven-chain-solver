# Your solver wallet address (must register on theseven.meme first)
SOLVER_ADDRESS=0xYourWalletAddress

# Your solver display name
SOLVER_NAME=My Seven Solver Node

# Country code (for leaderboard)
SOLVER_COUNTRY=US

# Seven Chain API endpoint
API_BASE=https://theseven.meme

# Your node's public RPC URL (used for registration)
SOLVER_RPC_URL=https://your-node.example.com:8545

# Minimum fee to bother filling (in sUSDT)
MIN_FEE_THRESHOLD=0.01

# How often to poll for open intents (milliseconds)
POLL_INTERVAL_MS=10000

# Which source chains to fill (comma-separated)
SUPPORTED_CHAINS=ETH,BNB

# Which tokens to fill (comma-separated)
SUPPORTED_TOKENS=ETH,BNB,USDT
