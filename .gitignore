# Dependencies
  node_modules/
  npm-debug.log*
  yarn-debug.log*
  yarn-error.log*

  # Build output
  dist/
  build/
  *.js.map

  # Environment & secrets — NEVER commit these
  .env
  .env.local
  .env.*.local
  .env.production
  .env.staging
  *.pem
  *.key
  *.p12
  *.pfx
  *.crt
  *.cer
  wallet.json
  keystore/
  private_keys/
  mnemonic.txt

  # Logs
  logs/
  *.log
  pm2*.log

  # Runtime
  pids/
  *.pid
  *.seed

  # OS
  .DS_Store
  Thumbs.db
  desktop.ini

  # IDE
  .vscode/
  .idea/
  *.swp
  *.swo

  # Test coverage
  coverage/
  .nyc_output/

  # Docker volumes
  data/
  chaindata/
  geth/
  